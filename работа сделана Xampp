-- 1. Создание базы данных
CREATE DATABASE IF NOT EXISTS SQLpäringud;
USE SQLpäringud;

-- 2. Таблицы
CREATE TABLE firma(
    firmaID INT AUTO_INCREMENT PRIMARY KEY,
    firmanimi VARCHAR(50),
    aadress VARCHAR(100),
    telefon VARCHAR(20)
);

CREATE TABLE praktikajuhendaja(
    praktikajuhendajaID INT AUTO_INCREMENT PRIMARY KEY,
    eesnimi VARCHAR(30),
    perekonnanimi VARCHAR(30),
    synniaeg DATE,
    telefon VARCHAR(20),
    palk INT,
    boonus INT
);

CREATE TABLE praktikabaas(
    praktikabaasID INT AUTO_INCREMENT PRIMARY KEY,
    firmaID INT,
    praktikatingimused VARCHAR(50),
    arvutiprogramm VARCHAR(50),
    juhendajaID INT,
    FOREIGN KEY (firmaID) REFERENCES firma(firmaID),
    FOREIGN KEY (juhendajaID) REFERENCES praktikajuhendaja(praktikajuhendajaID)
);

