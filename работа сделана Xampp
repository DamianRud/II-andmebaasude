-- 4. Функции (Важно: DELIMITER нужен для корректного парсинга в XAMPP/phpMyAdmin)

DELIMITER //

-- Функция расчета возраста (числом)
CREATE FUNCTION CalculateAge(DOB DATE) 
RETURNS INT
DETERMINISTIC
BEGIN
    RETURN TIMESTAMPDIFF(YEAR, DOB, CURDATE());
END //

-- Функция детального возраста (текстом)
CREATE FUNCTION fnComputeAge(DOB DATE) 
RETURNS VARCHAR(100)
DETERMINISTIC
BEGIN
    DECLARE years INT;
    DECLARE months INT;
    DECLARE days INT;
    DECLARE temp_date DATE;

    SET years = TIMESTAMPDIFF(YEAR, DOB, CURDATE());
    SET temp_date = DATE_ADD(DOB, INTERVAL years YEAR);
    
    SET months = TIMESTAMPDIFF(MONTH, temp_date, CURDATE());
    SET temp_date = DATE_ADD(temp_date, INTERVAL months MONTH);
    
    SET days = DATEDIFF(CURDATE(), temp_date);

    RETURN CONCAT(years, ' Years ', months, ' Months ', days, ' Days old');
END //

-- 5. Процедуры

CREATE PROCEDURE AvgPalk()
BEGIN
    SELECT AVG(palk) AS keskmine_palk FROM praktikajuhendaja;
END //

CREATE PROCEDURE AddFirma(
    IN f_nimi VARCHAR(50), 
    IN f_aadress VARCHAR(100), 
    IN f_tel VARCHAR(20)
)
BEGIN
    INSERT INTO firma (firmanimi, aadress, telefon) VALUES (f_nimi, f_aadress, f_tel);
END //

DELIMITER ;

-- 6. Примеры запросов

-- Использование функций в SELECT
SELECT 
    eesnimi AS Eesnimi, 
    perekonnanimi AS Perekonnanimi, 
    synniaeg AS Sünnikuupäev,
    fnComputeAge(synniaeg) AS Vanus_v1,
    CalculateAge(synniaeg) AS Vanus_v2
FROM praktikajuhendaja;

-- Вызов процедур
CALL AvgPalk();
CALL AddFirma('NewCompany', 'Tallinn', '5559999');

