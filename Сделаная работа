Create DATABASE SQLpäringud;
use SQLpäringud;


CREATE TABLE firma(
    firmaID INT IDENTITY(1,1) PRIMARY KEY,
    firmanimi VARCHAR(50),
    aadress VARCHAR(100),
    telefon VARCHAR(20)
);





CREATE TABLE praktikajuhendaja(
    praktikajuhendajaID INT IDENTITY(1,1) PRIMARY KEY,
    eesnimi VARCHAR(30),
    perekonnanimi VARCHAR(30),
    synniaeg DATE,
    telefon VARCHAR(20)
);




CREATE TABLE praktikabaas(
    praktikabaasID INT IDENTITY(1,1) PRIMARY KEY,
    firmaID INT,
    praktikatingimused VARCHAR(50),
    arvutiprogramm VARCHAR(50),
    juhendajaID INT,
    FOREIGN KEY (firmaID) REFERENCES firma(firmaID),
    FOREIGN KEY (juhendajaID) REFERENCES praktikajuhendaja(praktikajuhendajaID)
);



