-- =====================================================
-- ПРИМЕР РАБОТЫ ОПЕРАТОРА BETWEEN В MySQL
-- =====================================================

-- -----------------------------------------------------
-- 1. Создаем базу данных
-- -----------------------------------------------------
CREATE DATABASE IF NOT EXISTS test_between;

-- используем базу
USE test_between;

-- -----------------------------------------------------
-- 2. Создаем таблицу students
-- -----------------------------------------------------
CREATE TABLE students (
    id INT AUTO_INCREMENT PRIMARY KEY,  -- уникальный ID
    name VARCHAR(50),                   -- имя студента
    age INT,                            -- возраст
    grade INT                           -- оценка
);

-- -----------------------------------------------------
-- 3. Добавляем тестовые данные
-- -----------------------------------------------------
INSERT INTO students (name, age, grade) VALUES
('Alex', 18, 75),
('Anna', 20, 90),
('Maria', 22, 85),
('Daniel', 19, 60),
('Andrew', 21, 95),
('Olga', 23, 70);

-- -----------------------------------------------------
-- 4. Посмотреть все данные
-- -----------------------------------------------------
SELECT * FROM students;

-- =====================================================
-- ПРИМЕРЫ BETWEEN
-- =====================================================

-- -----------------------------------------------------
-- ПРИМЕР 1
-- Найти студентов возрастом от 18 до 21
-- -----------------------------------------------------
SELECT * FROM students
WHERE age BETWEEN 18 AND 21;

-- работает как:
-- WHERE age >= 18 AND age <= 21


-- -----------------------------------------------------
-- ПРИМЕР 2
-- Найти студентов с оценкой от 70 до 90
-- -----------------------------------------------------
SELECT * FROM students
WHERE grade BETWEEN 70 AND 90;

-- результат может быть:
-- Alex
-- Maria
-- Olga
-- Anna


-- -----------------------------------------------------
-- ПРИМЕР 3
-- BETWEEN можно использовать и для текста
-- -----------------------------------------------------
SELECT * FROM students
WHERE name BETWEEN 'A' AND 'M';

-- Найдет имена в алфавитном диапазоне
-- например:
-- Alex
-- Anna
-- Daniel


-- -----------------------------------------------------
-- ПРИМЕР 4
-- NOT BETWEEN
-- найти студентов НЕ в диапазоне
-- -----------------------------------------------------
SELECT * FROM students
WHERE age NOT BETWEEN 18 AND 21;

-- результат:
-- Maria
-- Olga


-- =====================================================
-- КРАТКО
-- =====================================================

-- BETWEEN 10 AND 20
-- означает:
-- >= 10 AND <= 20

-- NOT BETWEEN
-- означает:
-- < 10 OR > 20
