-- =====================================================
-- ПРИМЕР РАБОТЫ ОПЕРАТОРА LIKE В MySQL
-- Запускать можно в phpMyAdmin (XAMPP)
-- =====================================================

-- -----------------------------------------------------
-- 1. Создаем базу данных (если нужно)
-- -----------------------------------------------------
CREATE DATABASE IF NOT EXISTS test_like;

-- Используем эту базу
USE test_like;

-- -----------------------------------------------------
-- 2. Создаем таблицу users
-- -----------------------------------------------------
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,   -- уникальный ID пользователя
    name VARCHAR(50)                     -- имя пользователя
);

-- -----------------------------------------------------
-- 3. Добавляем тестовые данные
-- -----------------------------------------------------
INSERT INTO users (name) VALUES
('Alex'),
('Anna'),
('Andrew'),
('Maria'),
('Daniel'),
('Anastasia'),
('Al'),
('Ax');

-- -----------------------------------------------------
-- 4. Посмотрим все данные в таблице
-- -----------------------------------------------------
SELECT * FROM users;

-- =====================================================
-- ПРИМЕРЫ ОПЕРАТОРА LIKE
-- =====================================================

-- -----------------------------------------------------
-- ПРИМЕР 1
-- LIKE 'A%'
-- % означает любое количество символов
-- Найдет все имена которые начинаются на букву A
-- -----------------------------------------------------
SELECT * FROM users
WHERE name LIKE 'A%';

-- Результат может быть:
-- Alex
-- Anna
-- Andrew
-- Anastasia
-- Al
-- Ax


-- -----------------------------------------------------
-- ПРИМЕР 2
-- LIKE '%a'
-- % перед буквой означает любые символы перед ней
-- Найдет имена которые заканчиваются на "a"
-- -----------------------------------------------------
SELECT * FROM users
WHERE name LIKE '%a';

-- Пример результата:
-- Maria
-- Anna


-- -----------------------------------------------------
-- ПРИМЕР 3
-- LIKE '%an%'
-- % с двух сторон означает
-- что "an" может быть в любой части слова
-- -----------------------------------------------------
SELECT * FROM users
WHERE name LIKE '%an%';

-- Пример результата:
-- Daniel
-- Andrew
-- Anastasia


-- -----------------------------------------------------
-- ПРИМЕР 4
-- LIKE 'A_'
-- _ означает ровно один любой символ
-- -----------------------------------------------------
SELECT * FROM users
WHERE name LIKE 'A_';

-- Результат:
-- Al
-- Ax


-- -----------------------------------------------------
-- ПРИМЕР 5
-- LIKE '_n%'
-- первый символ любой
-- второй символ n
-- -----------------------------------------------------
SELECT * FROM users
WHERE name LIKE '_n%';

-- Пример результата:
-- Anna
-- Andrew


-- =====================================================
-- КРАТКО ПРО СИМВОЛЫ
-- =====================================================

-- %  = любое количество символов
-- _  = один любой символ

-- Примеры:
-- 'A%'   -> начинается на A
-- '%A'   -> заканчивается на A
-- '%A%'  -> содержит A
-- 'A_'   -> A + один символ
