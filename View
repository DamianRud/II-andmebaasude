🧱 Исходные таблицы (как обычно в заданиях)
SQL
CREATE TABLE students (
    id INT,
    name VARCHAR(50),
    grade INT
);

CREATE TABLE courses (
    id INT,
    title VARCHAR(50)
);

CREATE TABLE enrollments (
    student_id INT,
    course_id INT
);
📘 ЗАДАНИЕ 1 (самое простое)
👉 Создать VIEW с учениками с оценкой выше 80
SQL
CREATE VIEW good_students AS
SELECT *
FROM students
WHERE grade > 80;
Проверка:
SQL
SELECT * FROM good_students;
📘 ЗАДАНИЕ 2
👉 Показать только имена студентов
SQL
CREATE VIEW student_names AS
SELECT name
FROM students;
📘 ЗАДАНИЕ 3
👉 VIEW с JOIN (часто дают)
Показать: имя студента + курс
SQL
CREATE VIEW student_courses AS
SELECT s.name, c.title
FROM students s
JOIN enrollments e ON s.id = e.student_id
JOIN courses c ON e.course_id = c.id;
Проверка:
SQL
SELECT * FROM student_courses;
